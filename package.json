{
  "name": "file-extension-inspect-kit",
  "version": "0.1.0",
  "description": "Inspect file extensions with explicit dotfile, compound extension, and validation policies.",
  "keywords": [
    "file-extension",
    "extension",
    "filename",
    "path",
    "dotfile",
    "compound-extension",
    "validation",
    "diagnostics",
    "typescript",
    "browser",
    "developer-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/file-extension-inspect-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/file-extension-inspect-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/file-extension-inspect-kit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
